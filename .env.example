# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Resend — for subscription expiry notifications
# Get your API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Admin email — receives subscription expiry notifications
ADMIN_EMAIL=admin@yourdomain.com

# Cron secret — a random string to secure the cron endpoint
# Generate one: openssl rand -hex 32
CRON_SECRET=replace-with-a-long-random-secret

# Customer session secret — signs httpOnly session cookies
# Generate one: openssl rand -hex 32
CUSTOMER_SESSION_SECRET=replace-with-a-long-random-secret

# Resend from email — the sender address for OTP emails
# Use onboarding@resend.dev for testing, or your verified domain in production
RESEND_FROM_EMAIL=onboarding@resend.dev

# WhatsApp number for subscription renewal confirmation
# Format: country code + number, no + or spaces (e.g. 919876543210 for India +91 98765 43210)
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210

# PhonePe QR Code — place your QR image at: public/phonepe-qr.png
# The renewal prompt will display this image automatically.

# PhonePe — get credentials from your PhonePe Business dashboard
# UAT host:  https://api-preprod.phonepe.com/apis/pg-sandbox
# PROD host: https://api.phonepe.com/apis/hermes
PHONEPE_MERCHANT_ID=your-merchant-id
PHONEPE_SALT_KEY=your-salt-key
PHONEPE_SALT_INDEX=1
PHONEPE_HOST=https://api.preprod.phonepe.com/apis/hermes
NEXT_PUBLIC_APP_URL=https://yourdomain.com
